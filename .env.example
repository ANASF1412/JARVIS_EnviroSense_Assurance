"""
Configuration example file
Copy this to .env and fill in your MongoDB connection details
"""

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=gigshield-ai

# App Configuration
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Feature Flags
ENABLE_PREDICTIVE_ALERTS=True
ENABLE_ZONE_RISK=True
ENABLE_FRAUD_DETECTION=True
ENABLE_API_AUTH=False
